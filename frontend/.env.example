# Copy to .env.local and fill in. .env.local is gitignored.

# --- Existing integrations ---
# Resend (contact form + hire notification email)
RESEND_API_KEY=
# GitHub token (raises API rate limit for repo/activity widgets)
GITHUB_TOKEN=
# PostHog analytics (public, safe to expose)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# --- devOS Concierge (Ask devOS) ---
# Required for the AI concierge. Without it, /api/concierge returns 503 and the
# Spotlight "Ask devOS" panel shows a graceful offline fallback.
ANTHROPIC_API_KEY=
# Optional. Defaults to claude-opus-4-8. Set to claude-haiku-4-5 to cut cost.
CONCIERGE_MODEL=
# Optional. Durable per-IP rate limiting + daily spend ceiling (Upstash free
# tier). If unset, the concierge still works but is not throttled — set these
# before exposing it publicly.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
